{
  "name": "haven",
  "version": "0.0.1",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "haven",
      "version": "0.0.1",
      "workspaces": [
        "apps/*",
        "apps/backend/*",
        "packages/*"
      ]
    },
    "apps/backend/api": {
      "name": "@haven/api",
      "version": "0.0.1"
    },
    "apps/backend/openclaw": {
      "name": "@haven/openclaw",
      "version": "0.0.1"
    },
    "apps/voice-agent": {
      "name": "@haven/voice-agent",
      "version": "0.0.1"
    },
    "apps/web": {
      "name": "@haven/web",
      "version": "0.0.1"
    },
    "node_modules/@haven/api": {
      "resolved": "apps/backend/api",
      "link": true
    },
    "node_modules/@haven/openclaw": {
      "resolved": "apps/backend/openclaw",
      "link": true
    },
    "node_modules/@haven/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/@haven/voice-agent": {
      "resolved": "apps/voice-agent",
      "link": true
    },
    "node_modules/@haven/web": {
      "resolved": "apps/web",
      "link": true
    },
    "packages/shared": {
      "name": "@haven/shared",
      "version": "0.0.1"
    }
  }
}
